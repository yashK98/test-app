# --- Database ---
# Default is a local SQLite file (no setup). To use Postgres instead:
#   DATABASE_URL=postgresql+psycopg://drift:drift@localhost:5432/drift
# (and uncomment psycopg in requirements.txt)
DATABASE_URL=sqlite:///./drift.db

# --- Kubernetes binaries ---
KUBECTL_BIN=kubectl
SKECTL_BIN=skectl

# Command that authenticates you to the cluster. Leave blank if you run skectl
# yourself in a terminal before starting the backend.
#   e.g. SKECTL_CMD=skectl get-token
SKECTL_CMD=

# Set true only if skectl prints a bearer token on stdout (we pass it to
# kubectl via --token). Leave false if skectl updates your kubeconfig.
SKECTL_TOKEN_MODE=false

# Optional: force a kubeconfig context on every kubectl call
KUBECTL_CONTEXT=

TOKEN_TTL=900
KUBECTL_TIMEOUT=30
AUTH_TIMEOUT=120
